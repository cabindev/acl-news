# ===== Google Gemini (orchestrator + summarizer) =====
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ===== Tavily (news search) =====
TAVILY_API_KEY=

# ===== Telegram delivery — optional =====
# Create a bot with @BotFather to get TELEGRAM_BOT_TOKEN.
# Get TELEGRAM_CHAT_ID by messaging your bot then visiting
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Adobe Express — optional =====
# Get a client ID at https://developer.adobe.com/express/embed-sdk/
ADOBE_CLIENT_ID=

# ===== Google Sheet logging — optional =====
# Deploy an Apps Script Web App bound to your Sheet (see README) and paste its
# /exec URL here. Each published briefing is appended as a row.
SHEET_WEBHOOK_URL=

# ===== Tunables =====
ORCHESTRATOR_MODEL=gemini-2.0-flash
SUMMARIZER_MODEL=gemini-1.5-flash
MAX_RESULTS_PER_QUERY=8
TOP_N=5
# อายุข่าวสูงสุด (วัน) — ลดเป็น 3 หรือ 2 ถ้าต้องการข่าวสดกว่านี้
MAX_AGE_DAYS=7
